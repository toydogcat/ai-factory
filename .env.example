# AI-Factory Environment Variables Template

# --- Database Setup ---
# Postgres Host (If running via run.sh on host, use 127.0.0.1)
POSTGRES_SERVER=127.0.0.1
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=ai_factory

# --- AI API Keys ---
# Get your keys at https://aistudio.google.com/ and https://tavily.com/
GEMINI_API_KEY=your_gemini_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here

# --- App Settings ---
APP_PORT=8001
SECRET_KEY=generate_a_secure_random_string_here

# --- Container Settings ---
# Default image for instances if not specified
DEFAULT_INSTANCE_IMAGE=ai-tarot-backend:latest
NETWORK_NAME=traefik-public
